{
  "functions": {
    "api/ask.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://ericismyhero.github.io" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
